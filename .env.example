# FatimaZehra-AI-Tutor Environment Variables
# Copy to .env.local (frontend) and .env (backend), then fill with real values
# NEVER commit .env files — this file contains no secrets, only examples

# ==================== OpenAI ====================
# GPT-4 API key for AI chat and analysis features
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ==================== Stripe (TEST MODE ONLY) ====================
# Use TEST MODE keys during development (sk_test_, pk_test_)
# Switch to live keys only in production
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==================== Database (Neon PostgreSQL) ====================
# Neon connection string with asyncpg driver
# Format: postgresql+asyncpg://user:password@host/database
# Get from: https://console.neon.tech
DATABASE_URL=postgresql+asyncpg://...

# ==================== NextAuth.js ====================
# Generate with: openssl rand -base64 32
# Used to encrypt session tokens and JWT
NEXTAUTH_SECRET=

# Callback URL for OAuth redirects and session cookie
# Must match configured OAuth app redirect URIs
NEXTAUTH_URL=http://localhost:3000

# ==================== Frontend App ====================
# Public API URL (frontend talks to backend)
# Must be accessible from browser
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API base URL (used in browser)
# Must be accessible from browser client
# Local dev: http://localhost:8000
# Docker: http://backend:8000
# Production: https://api.example.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==================== Backend Server URL (PRIVATE) ====================
# Server-side backend URL (used by NextAuth on Node.js server)
# Used for: NextAuth authorize callback, session refresh
# Local dev with WSL2 backend: http://172.21.174.124:8000 (WSL IP)
# Local dev with host backend: http://localhost:8000
# Docker: http://backend:8000
# NOTE: Not exposed to browser, only used on server
BACKEND_URL=http://localhost:8000

# ==================== Redis (Upstash) ====================
# Redis connection for rate limiting and caching
# Format: redis://default:[password]@[host]:[port]
# Get from: https://console.upstash.com
# Phase 1: Optional (rate limiting stubbed); Phase 3: Required
REDIS_URL=

# ==================== Sentry (Error Tracking) ====================
# DSN for frontend and backend error tracking
# Get from: https://sentry.io/onboarding/
# Phase 1: Optional; Phase 3: Required
SENTRY_DSN=

# ==================== Resend (Email) ====================
# API key for sending transactional emails
# Get from: https://resend.com/api-keys
# Phase 2+: Required for email notifications
RESEND_API_KEY=

# ==================== Environment ====================
# Options: development, production, staging
ENV=development

# ==================== Backend Database Debug ====================
# Enable SQLAlchemy query logging (very verbose - for debugging only)
# Options: true, false
SQL_ECHO=false

# ==================== Optional: Google OAuth ====================
# For OAuth login (NextAuth.js GoogleProvider)
# Get from: https://console.cloud.google.com/
# Phase 2+: Implement Google login
OAUTH_GOOGLE_ID=
OAUTH_GOOGLE_SECRET=

# ==================== Optional: Admin Secret ====================
# Simple auth for /admin endpoints
# Generate random string
ADMIN_SECRET=
